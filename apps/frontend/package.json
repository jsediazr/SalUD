{
   "name": "frontend-react",
   "private": true,
   "version": "0.1.0",
   "type": "module",
   "scripts": {
      "dev": "vite --host 0.0.0.0 --port 8080",
      "build": "vite build",
      "build-dev": "tsc && vite build --mode dev",
      "build-test": "tsc && vite build --mode testing",
      "lint": "eslint .",
      "preview": "vite preview",
      "format": "prettier --write \"./src/**/*.tsx\"",
      "format-check": "prettier --list-different \"./src/**/*.tsx\"",
      "test": "jest --config jest.config.cjs --coverage",
      "test:watch": "jest --config jest.config.cjs --watch --coverage=false",
      "test:coverage": "jest --config jest.config.cjs --coverage"
   },
   "dependencies": {
      "@emotion/react": "^11.14.0",
      "@emotion/styled": "^11.14.0",
      "@mui/icons-material": "^6.1.9",
      "@mui/lab": "^6.0.0-beta.15",
      "@mui/material": "^6.1.9",
      "@mui/x-date-pickers": "^7.22.2",
      "@mui/x-date-pickers-pro": "^7.22.2",
      "@vitejs/plugin-react": "^4.3.4",
      "axios": "^1.8.4",
      "axios-hooks": "^5.1.1",
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "react-router": "^7.6.0",
      "react-router-dom": "^7.6.0",
      "sweetalert2": "^11.26.22",
      "uuid": "^11.1.0",
      "zustand": "^5.0.3"
   },
   "devDependencies": {
      "@eslint/js": "^9.21.0",
      "@testing-library/jest-dom": "^6.8.0",
      "@testing-library/react": "^14.3.1",
      "@testing-library/user-event": "^14.5.1",
      "@types/jest": "^30.0.0",
      "@types/node": "20.11.30",
      "@types/react": "^18.3.28",
      "@types/react-dom": "^18.3.5",
      "@types/react-router": "^5.1.20",
      "@types/testing-library__jest-dom": "^6.0.0",
      "@types/testing-library__react": "^10.2.0",
      "@types/uuid": "^10.0.0",
      "@typescript-eslint/eslint-plugin": "^8.29.1",
      "@typescript-eslint/parser": "^8.29.1",
      "eslint": "^9.21.0",
      "eslint-plugin-react-hooks": "^5.1.0",
      "eslint-plugin-react-refresh": "^0.4.19",
      "globals": "^15.15.0",
      "jest": "^30.2.0",
      "jest-environment-jsdom": "^29.7.0",
      "ts-jest": "^29.4.5",
      "typescript": "~5.7.2",
      "typescript-eslint": "^8.24.1",
      "vite": "6.2.4"
   }
}
